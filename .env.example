# ===========================================================================
# amex-sync — Config
#
# Copy this file in .env and fill the values.
# The fields with ENC:... must be encrypted using: npm run encrypt
# ===========================================================================

# --- AMEX -------------------------------------------------------------------
AMEX_USERNAME=ENC:...
AMEX_PASSWORD=ENC:...
AMEX_ACCOUNT_TOKEN=

# --- Email (IMAP) --------------------------------------------------
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_IMAP_PORT=993
EMAIL_USERNAME=
EMAIL_PASSWORD=ENC:...
EMAIL_SENDER_FILTER=americanexpress

# --- Actual Budget ----------------------------------------------------------
ACTUAL_SERVER_URL=http://localhost:5006
ACTUAL_PASSWORD=ENC:...
ACTUAL_BUDGET_ID=
ACTUAL_ACCOUNT_ID=

# --- Sync -------------------------------------------------------------------
SYNC_FETCH_DAYS_BACK=7
OTP_POLL_INTERVAL_SEC=5
OTP_POLL_TIMEOUT_SEC=120
HTTP_TIMEOUT_MS=30000
HTTP_MAX_RETRIES=3

# --- Logging ----------------------------------------------------------------
LOG_LEVEL=info
