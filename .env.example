# ── Amex Italia credentials ──────────────────────────────────────────
AMEX_USERNAME=your_amex_userid
AMEX_PASSWORD=your_amex_password

# ── IMAP for 2FA OTP ────────────────────────────────────────────────
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=your_email@gmail.com
IMAP_PASSWORD=your_app_specific_password
# Optional: subfolder (default INBOX)
# IMAP_FOLDER=INBOX

# ── Actual Budget ───────────────────────────────────────────────────
ACTUAL_SERVER_URL=http://localhost:5006
ACTUAL_PASSWORD=your_actual_password
ACTUAL_SYNC_ID=your_budget_sync_id
# Optional: end-to-end encryption password (if enabled in Actual)
# ACTUAL_ENCRYPTION_PASSWORD=your_encryption_password
# Optional: data directory for Actual API cache (default: ./actual-data)
# ACTUAL_DATA_DIR=./actual-data

# ── Account mapping ────────────────────────────────────────────────
# Amex account_token → Actual account ID (comma-separated pairs)
# Format: amex_token1:actual_id1,amex_token2:actual_id2
ACCOUNT_MAPPING=amex_account_token:actual_account_id

# ── Optional ────────────────────────────────────────────────────────
# Path to cookies file (default: ./amex.json)
# AUTH_JSON_PATH=./amex.json
# Proxy for datacenter/VPS environments
# PROXY_URL=socks5://10.0.0.1:1080
# Cron schedule for Docker mode (default: every 4 hours)
# SYNC_CRON=0 */4 * * *
# Log level: debug, info, warn, error
# LOG_LEVEL=info
